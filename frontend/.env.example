# ── API Backend URL ───────────────────────────────────────────────────────────
# Set this to the URL of your deployed Express backend.
# Leave empty to use the built-in Next.js API routes (local dev without backend).
NEXT_PUBLIC_API_URL=https://api.quiz.vin

# The backend must have your frontend URL in ALLOWED_ORIGINS, e.g.:
#   ALLOWED_ORIGINS=https://your-app.vercel.app

# ── Built-in Next.js API routes (only needed when NOT using standalone backend) ─
# 默认使用 27018 端口，避免与其他项目的 27017 冲突
MONGODB_URI=mongodb://localhost:27018/quizmaster
JWT_SECRET=change_me_to_a_random_secret_string
NEXT_PUBLIC_APP_URL=http://localhost:3000
