# ── Local dev (no standalone backend) ──────────────────────────────────────────
# Leave NEXT_PUBLIC_API_URL empty to use the built-in Next.js API routes.
NEXT_PUBLIC_API_URL=

# ── Production on Vercel (pointing at standalone backend) ─────────────────────
# Set this to the URL of your deployed Express backend, e.g.:
# NEXT_PUBLIC_API_URL=https://api.your-server.com
#
# The backend must have your Vercel deployment URL in ALLOWED_ORIGINS, e.g.:
#   ALLOWED_ORIGINS=https://your-app.vercel.app

# ── Built-in Next.js API routes (only needed when NOT using standalone backend) ─
# 默认使用 27018 端口，避免与其他项目的 27017 冲突
MONGODB_URI=mongodb://localhost:27018/quizmaster
JWT_SECRET=change_me_to_a_random_secret_string
NEXT_PUBLIC_APP_URL=http://localhost:3000
