PORT=5000
NODE_ENV=development

# Supabase Postgres: Project Settings → Database → Connection string (URI, port 5432)
# Or local: postgresql://quizmaster:quizmaster@localhost:5433/quizmaster
DATABASE_URL=postgresql://USER:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres

JWT_SECRET=change_me_to_a_long_random_string

# Comma-separated origins for browser requests (Vercel frontend URL)
ALLOWED_ORIGINS=http://localhost:3000
