# MongoDB connection string
# For local (default port 27018 to avoid conflicts with other projects):
#   mongodb://localhost:27018/quizmaster
# For Docker Compose (container internal port is always 27017):
#   mongodb://mongo:27017/quizmaster
# For Atlas:
#   mongodb+srv://<user>:<password>@cluster.mongodb.net/quizmaster
MONGODB_URI=mongodb://localhost:27018/quizmaster

# JWT secret — change this to a long random string in production
JWT_SECRET=change_me_to_a_random_secret_string

# Port the backend listens on
PORT=5000

# Comma-separated list of allowed frontend origins (CORS)
# Example for production: https://your-app.vercel.app,https://www.your-domain.com
ALLOWED_ORIGINS=http://localhost:3000

# Node environment: development | production
NODE_ENV=development
